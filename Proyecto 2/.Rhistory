# =========================================================================
# is.final.state(state, final_state, problem)
# =========================================================================
# PURPOSE:
#   Checks if the board is full.
#   (Since is.applicable ensures validity, a full board is a solution).
# =========================================================================
is.final.state <- function (state, final_state, problem) {
return(!any(state == 0))
}
