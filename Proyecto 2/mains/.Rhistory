random.restart.hill.climbing <- function(file,
max_iterations = 100,
count_print = 5, restarts= 0) {
name_method      <- "Random Restart Hill Climbing"
source(file)
print("hollllll")
print(initialize.problem)
print("hollllll")
print(paste0("* START: ", name_method), quote = FALSE)
start_time <- Sys.time()
# Pre-allocate report vectors for performance
rep_iteration     <- numeric(max_iterations)
rep_eval_current  <- numeric(max_iterations)
rep_eval_neighbor <- numeric(max_iterations)
count <- 1
end_reason <- NULL
}
